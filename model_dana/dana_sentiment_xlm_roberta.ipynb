        "id": "hRfHKhNJKUlr"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "train_texts, temp_texts, train_labels, temp_labels = train_test_split(\n",
        "    df_balanced[\"ulasan\"],\n",
        "    df_balanced[\"label\"],\n",
        "    test_size=0.2,\n",
        "    stratify=df_balanced[\"label\"],\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "val_texts, test_texts, val_labels, test_labels = train_test_split(\n",
        "    temp_texts,\n",
        "    temp_labels,\n",
        "    test_size=0.5,\n",
        "    stratify=temp_labels,\n",
        "    random_state=42\n",
        ")"
      ],
      "metadata": {
        "id": "NB8unAI0KXhw"
