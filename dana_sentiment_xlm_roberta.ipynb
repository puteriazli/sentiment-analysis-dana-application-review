    {
      "cell_type": "markdown",
      "source": [
        "# **Import Library**"
      ],
      "metadata": {
        "id": "RKEkbNBQJW0w"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "import emoji\n",
        "import torch\n",
        "import random\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from datasets import Dataset\n",
        "from transformers import (\n",
        "    XLMRobertaTokenizer,\n",
        "    XLMRobertaForSequenceClassification,\n",
        "    TrainingArguments,\n",
        "    Trainer\n",
        ")\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.metrics import (\n",
        "    classification_report,\n",
        "    confusion_matrix,\n",
        "    accuracy_score,\n",
        "    f1_score,\n",
        "    cohen_kappa_score\n",
        ")"
      ],
      "metadata": {
        "id": "rtyFTJKdJag3"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **Load Dataset**"
      ],
      "metadata": {
        "id": "rnPRrkGdJezM"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df = pd.read_parquet('/content/drive/MyDrive/Project Mandiri/Sentiment Analysis DANA/data/ulasan_dana_cleaned.parquet')"
      ],
      "metadata": {
        "id": "5rdobjcPJikm"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **Mapping Rating в†’ Sentiment**"
      ],
      "metadata": {
        "id": "A6-YrcRhJn1t"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def map_label(rating):\n",
        "    if rating <= 2:\n",
        "        return 0  # negatif\n",
        "    elif rating == 3:\n",
        "        return 1  # netral\n",
        "    else:\n",
        "        return 2  # positif\n",
        "\n",
        "df[\"label\"] = df[\"rating\"].apply(map_label)"
      ],
      "metadata": {
        "id": "kOf2phbBJrqo"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **FILTER KUALITAS DATA (REALISTIC FILTER)**"
      ],
      "metadata": {
        "id": "wwRq6blxJvNs"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Buang emoji-only"
      ],
      "metadata": {
        "id": "gQYX52sJJzYg"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def is_emoji_only(text):\n",
        "    text_no_emoji = emoji.replace_emoji(str(text), replace='')\n",
        "    text_no_emoji = re.sub(r'[^a-zA-Z]', '', text_no_emoji)\n",
        "    return len(text_no_emoji.strip()) == 0\n",
        "\n",
        "df = df[~df[\"ulasan\"].apply(is_emoji_only)]"
      ],
      "metadata": {
        "id": "YMt-c_gNJ2Ay"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Buang laughter/noise-only"
      ],
      "metadata": {
        "id": "eKxtpBWcJ4Sm"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def is_noise(text):\n",
        "    text = str(text).lower().strip()\n",
        "    return bool(re.fullmatch(r\"(wkwk+|wk+|haha+|hehe+|hihi+)\", text))\n",
        "\n",
        "df = df[~df[\"ulasan\"].apply(is_noise)]"
      ],
